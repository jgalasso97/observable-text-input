{
  "name": "observable-text-input",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "node --require ./server/otel.js ./server/app.js",
    "start:client": "npm run dev --prefix ./client"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.40.3",
    "@opentelemetry/auto-instrumentations-web": "^0.35.0",
    "@opentelemetry/instrumentation-fetch": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}